{
	"name": "kanbambam",
	"version": "1.0.3",
	"description": "CLI-first Kanban board management — create and manage boards, columns, and items from your terminal",
	"type": "module",
	"license": "MIT",
	"bin": {
		"kanbambam": "./dist/index.js"
	},
	"files": [
		"dist"
	],
	"keywords": [
		"kanban",
		"cli",
		"board",
		"project-management",
		"trello",
		"terminal",
		"ai-agent"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/rrico321/Kanbambam.git",
		"directory": "apps/cli"
	},
	"homepage": "https://kanbambam.vercel.app",
	"scripts": {
