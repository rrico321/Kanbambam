		"jose": "^6.2.2",
		"open": "^11",
		"react": "^19"
	},
	"devDependencies": {
		"@kanbambam/shared": "workspace:*",
		"@types/react": "^19",
		"tsup": "^8",
		"tsx": "^4",
		"typescript": "^5.8",
		"vitest": "^3"
	}
